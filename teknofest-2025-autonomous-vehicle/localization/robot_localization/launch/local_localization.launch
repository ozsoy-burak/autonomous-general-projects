<launch>
  <node pkg="robot_localization" type="ekf_localization_node" name="local_localization" clear_params="true">
    <rosparam command="load" file="$(find robot_localization)/params/local_localization.yaml" />

    <!--  Placeholder for output topic remapping
    <remap from="odometry/filtered" to=""/>
    <remap from="accel/filtered" to=""/>
    -->

  </node>
</launch>

